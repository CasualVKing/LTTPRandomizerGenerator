<Window x:Class="LTTPRandomizerGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LTTPRandomizerGenerator.Controls"
        Title="LTTP Randomizer Generator"
        Width="680" Height="820"
        MinWidth="600" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI" FontSize="13"
        Icon="Resources/icon.ico">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20" Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- file pickers -->
            <RowDefinition Height="Auto"/>  <!-- separator -->
            <RowDefinition Height="Auto"/>  <!-- preset row -->
            <RowDefinition Height="*"/>     <!-- settings -->
            <RowDefinition Height="Auto"/>  <!-- generate button -->
            <RowDefinition Height="Auto"/>  <!-- progress + status -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="LTTP Randomizer Generator"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Text="Generate a randomized A Link to the Past ROM via alttpr.com"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- File pickers -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Base ROM:"
                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="RomPathBox" IsReadOnly="True"
                       Style="{StaticResource DarkTextBox}"
                       Text="{Binding RomPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       VerticalAlignment="Center"/>
            <Button    Grid.Row="0" Grid.Column="2" Content="Browse..." Margin="6,0,0,0"
                       Style="{StaticResource DarkButton}"
                       Click="BrowseRom_Click"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Output Folder:"
                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="2" Grid.Column="1" IsReadOnly="True"
                       Style="{StaticResource DarkTextBox}"
                       Text="{Binding OutputFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       VerticalAlignment="Center"/>
            <Button    Grid.Row="2" Grid.Column="2" Content="Browse..." Margin="6,0,0,0"
                       Style="{StaticResource DarkButton}"
                       Click="BrowseOutput_Click"/>

            <TextBlock Grid.Row="4" Grid.Column="1"
                       Text="ROMs are saved to a lttpr\ subfolder. Place it in your emulator's SNES ROMs directory."
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11" Margin="0,2,0,0"/>

            <!-- Seed input (optional, for racing) -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Seed (optional):"
                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="6" Grid.Column="1"
                       Style="{StaticResource DarkTextBox}"
                       Text="{Binding SeedInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Row="6" Grid.Column="2" Orientation="Horizontal">
                <Button Content="Load" Margin="6,0,0,0"
                        Style="{StaticResource DarkButton}"
                        IsEnabled="{Binding CanLoadSeed}"
                        Click="LoadSeed_Click"/>
                <Button Content="✕" Margin="4,0,0,0"
                        Style="{StaticResource DarkButton}"
                        Visibility="{Binding HasSeedHash, Converter={StaticResource BoolToVis}}"
                        Click="ClearSeed_Click"/>
            </StackPanel>
        </Grid>

        <Separator Grid.Row="2" Margin="0,10"/>

        <!-- Preset row -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Preset:"
                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="PresetCombo"
                      Style="{StaticResource DarkComboBox}"
                      ItemsSource="{Binding AllPresets}"
                      SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      IsEnabled="{Binding IsSettingsEditable}"
                      SelectionChanged="PresetCombo_SelectionChanged"/>

            <TextBox   Grid.Column="2" x:Name="PresetNameBox" Width="140" Margin="6,0,0,0"
                       Style="{StaticResource DarkTextBox}"
                       Text="{Binding NewPresetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       IsEnabled="{Binding IsSettingsEditable}"
                       Visibility="{Binding IsCustomSelected, Converter={StaticResource BoolToVis}}"
                       VerticalAlignment="Center"/>

            <Button    Grid.Column="3" Content="Save" Margin="4,0,0,0"
                       Style="{StaticResource DarkButton}"
                       IsEnabled="{Binding CanSavePreset}"
                       Visibility="{Binding IsCustomSelected, Converter={StaticResource BoolToVis}}"
                       Click="SavePreset_Click"/>
            <Button    Grid.Column="4" Content="Delete" Margin="4,0,0,0"
                       Style="{StaticResource DangerOutlineButton}"
                       IsEnabled="{Binding CanDeletePreset}"
                       Visibility="{Binding IsUserPresetSelected, Converter={StaticResource BoolToVis}}"
                       Click="DeletePreset_Click"/>
        </Grid>

        <!-- Settings panel (Customization + Randomizer Settings) -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Sprite selection (always visible) -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Preview area: sprite image or random placeholder -->
                    <Grid Grid.Column="0" Grid.RowSpan="2"
                          Margin="0,0,10,0" VerticalAlignment="Center">

                        <!-- Normal sprite preview (hidden when random) -->
                        <controls:SpriteImageControl ImageUrl="{Binding EffectiveSpritePreviewUrl}">
                            <controls:SpriteImageControl.Style>
                                <Style TargetType="controls:SpriteImageControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRandomSprite}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </controls:SpriteImageControl.Style>
                        </controls:SpriteImageControl>

                        <!-- Random placeholder (shown when random is selected) -->
                        <Border Width="64" Height="64" CornerRadius="4" Background="#2A2A3A">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRandomSprite}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding RandomGlyph}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="28" FontWeight="Bold" Foreground="#DAA520"/>
                        </Border>

                    </Grid>

                    <!-- Sprite name -->
                    <TextBlock Grid.Column="1" Grid.Row="0"
                               Text="{Binding SpriteDisplayName}"
                               VerticalAlignment="Bottom"
                               Foreground="{StaticResource TextBrush}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,6,4"/>

                    <!-- Buttons -->
                    <StackPanel Grid.Column="2" Grid.RowSpan="2"
                                Orientation="Vertical" VerticalAlignment="Center">
                        <Button Content="Browse..." Margin="0,0,0,4"
                                Style="{StaticResource DarkButton}"
                                Click="BrowseSprite_Click"/>
                        <Button Content="Clear"
                                Style="{StaticResource DarkButton}"
                                Click="ClearSprite_Click"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,0,0,10" Background="{StaticResource BorderBrush}"/>

                <!-- Customization section -->
                <TextBlock Text="{Binding CustomizationToggleLabel}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           Cursor="Hand"
                           Margin="0,0,0,8"
                           MouseLeftButtonUp="ToggleCustomization_Click"/>

                <ItemsControl ItemsSource="{Binding CustomizationRows}"
                              Visibility="{Binding IsCustomizationExpanded, Converter={StaticResource BoolToVis}}"
                              Margin="0,0,0,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <ComboBox  Grid.Column="1"
                                           Style="{StaticResource DarkComboBox}"
                                           ItemsSource="{Binding Options}"
                                           SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                                           DisplayMemberPath="Display"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,4,0,10" Background="{StaticResource BorderBrush}"/>

                <!-- MSU Music Pack section -->
                <TextBlock Text="{Binding MsuToggleLabel}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           Cursor="Hand"
                           Margin="0,0,0,8"
                           MouseLeftButtonUp="ToggleMsu_Click"/>

                <StackPanel Visibility="{Binding IsMsuExpanded, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,10">

                    <!-- Pack info -->
                    <TextBlock Text="{Binding MsuPackSummary}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" Margin="0,0,0,6"
                               Visibility="{Binding HasMsuPack, Converter={StaticResource BoolToVis}}"/>

                    <!-- Import / Export buttons -->
                    <WrapPanel Margin="0,0,0,8">
                        <Button Content="Import .lttppack" Margin="0,0,6,4"
                                Style="{StaticResource DarkButton}" Click="ImportLttppack_Click"/>
                        <Button Content="Import OST Folder" Margin="0,0,6,4"
                                Style="{StaticResource DarkButton}" Click="ImportOstFolder_Click"/>
                        <Button Content="Import OST ZIP" Margin="0,0,6,4"
                                Style="{StaticResource DarkButton}" Click="ImportOstZip_Click"/>
                        <Button Content="Export .lttppack" Margin="0,0,6,4"
                                Style="{StaticResource DarkButton}" Click="ExportPack_Click"
                                IsEnabled="{Binding HasMsuPack}"/>
                        <Button Content="Clear Pack" Margin="0,0,6,4"
                                Style="{StaticResource DangerOutlineButton}" Click="ClearPack_Click"
                                IsEnabled="{Binding HasMsuPack}"/>
                    </WrapPanel>

                    <!-- Library folder config -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Library:"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding LibraryFolderDisplay}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="2" Content="Set Folder" Margin="6,0,0,0"
                                Style="{StaticResource DarkButton}" FontSize="11"
                                Click="SetLibraryFolder_Click"/>
                    </Grid>

                    <!-- Playlist row -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Playlist:"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentPlaylistName}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="2" Content="Save" Margin="6,0,0,0"
                                Style="{StaticResource DarkButton}" FontSize="11"
                                IsEnabled="{Binding HasMsuPack}"
                                Click="SavePlaylist_Click"/>
                        <Button Grid.Column="3" Content="Load" Margin="4,0,0,0"
                                Style="{StaticResource DarkButton}" FontSize="11"
                                Click="LoadPlaylist_Click"/>
                    </Grid>

                    <!-- Track search -->
                    <TextBox x:Name="TrackSearchBox"
                             Style="{StaticResource DarkTextBox}"
                             FontSize="11" Margin="0,0,0,6"
                             TextChanged="TrackSearch_TextChanged"/>

                    <!-- OST import progress -->
                    <TextBlock x:Name="MsuProgressText"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" Margin="0,0,0,4" Visibility="Collapsed"/>

                    <!-- Track list -->
                    <ItemsControl ItemsSource="{Binding MsuTracks}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2" ToolTip="{Binding ValidationError}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding SlotDisplay}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11" VerticalAlignment="Center"/>

                                    <!-- OST play button — next to track name -->
                                    <Button Grid.Column="1"
                                            Content="{Binding OriginalPlayButtonText}" FontSize="10"
                                            MinWidth="24" Padding="4,1" Margin="0,0,4,0"
                                            Style="{StaticResource DarkButton}"
                                            Visibility="{Binding HasOriginal, Converter={StaticResource BoolToVis}}"
                                            Click="PlayOriginal_Click" Tag="{Binding}"/>

                                    <TextBlock Grid.Column="2" Text="{Binding Name}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="11" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding TypeLabel}"
                                               Foreground="#888" FontSize="10"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding HasTypeLabel, Converter={StaticResource BoolToVis}}"/>

                                    <TextBlock Grid.Column="4" Text="{Binding FileName}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="4,0"/>

                                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                                        <Button Content="{Binding PlayButtonText}" FontSize="10"
                                                MinWidth="24" Padding="4,1"
                                                Style="{StaticResource DarkButton}"
                                                Visibility="{Binding HasFile, Converter={StaticResource BoolToVis}}"
                                                Click="PlayTrack_Click" Tag="{Binding}"/>
                                        <Button Content="..." FontSize="10"
                                                MinWidth="24" Padding="4,1" Margin="2,0,0,0"
                                                Style="{StaticResource DarkButton}"
                                                Click="AssignTrack_FromLibrary" Tag="{Binding}"/>
                                        <Button Content="×" FontSize="10"
                                                MinWidth="24" Padding="4,1" Margin="2,0,0,0"
                                                Style="{StaticResource DarkButton}"
                                                Visibility="{Binding HasFile, Converter={StaticResource BoolToVis}}"
                                                Click="ClearTrack_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Include MSU toggle -->
                    <CheckBox Content="Include MSU music pack with generated ROM"
                              Foreground="{StaticResource TextBrush}"
                              IsChecked="{Binding IncludeMsuPack}"
                              IsEnabled="{Binding HasMsuPack}"
                              Margin="0,0,0,4"/>

                    <!-- Library picker popup -->
                    <Popup x:Name="LibraryPopup" StaysOpen="False"
                           Placement="Bottom" AllowsTransparency="True">
                        <Border Background="#2A2A3E" BorderBrush="#3A3A55"
                                BorderThickness="1" CornerRadius="4" Padding="8"
                                MinWidth="320" MaxHeight="400">
                            <StackPanel>
                                <TextBlock x:Name="LibraryPopupTitle"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11" Margin="0,0,0,6"/>
                                <TextBox x:Name="LibrarySearchBox"
                                         Style="{StaticResource DarkTextBox}"
                                         FontSize="11" Margin="0,0,0,4"
                                         TextChanged="LibrarySearch_TextChanged"/>
                                <TextBlock x:Name="LibraryCountText"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="10" Margin="0,0,0,4"/>
                                <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="LibraryList"/>
                                </ScrollViewer>
                                <Button Content="Browse File..." Margin="0,6,0,0"
                                        Style="{StaticResource DarkButton}" FontSize="11"
                                        Click="LibraryBrowseFile_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <Separator Margin="0,0,0,10" Background="{StaticResource BorderBrush}"/>

                <!-- Randomizer Settings section -->
                <TextBlock Text="{Binding SettingsToggleLabel}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           Cursor="Hand"
                           Margin="0,0,0,8"
                           MouseLeftButtonUp="ToggleSettings_Click"/>

                <ItemsControl ItemsSource="{Binding SettingRows}"
                              Visibility="{Binding IsSettingsExpanded, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <ComboBox  Grid.Column="1"
                                           Style="{StaticResource DarkComboBox}"
                                           ItemsSource="{Binding Options}"
                                           SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                                           DisplayMemberPath="Display"
                                           IsEnabled="{Binding IsEnabled}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- Generate button -->
        <Button Grid.Row="5" Content="Generate ROM"
                Style="{StaticResource AccentButton}"
                IsEnabled="{Binding CanGenerate}"
                Margin="0,12,0,0"
                Click="Generate_Click"/>

        <!-- Progress + status -->
        <StackPanel Grid.Row="6" Margin="0,8,0,0">
            <ProgressBar Style="{StaticResource DarkProgressBar}"
                         IsIndeterminate="{Binding IsGenerating}"
                         Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{Binding StatusColor}"
                       Margin="0,6,0,0" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                        Visibility="{Binding HasSeedLink, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding SeedPermalink}"
                           Foreground="{StaticResource AccentBrush}"
                           TextDecorations="Underline" Cursor="Hand"
                           MouseLeftButtonUp="SeedLink_Click"/>
                <Button Content="Copy" Margin="8,0,0,0"
                        Style="{StaticResource DarkButton}"
                        Click="CopySeed_Click" FontSize="11" Padding="6,2"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
