<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="3dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView android:id="@+id/slotNumber"
        android:textColor="#888899" android:textSize="11sp"
        android:minWidth="28dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <!-- OST play button -->
    <Button android:id="@+id/playOrigBtn"
        android:textColor="#E0E0F0" android:textSize="10sp"
        android:backgroundTint="#3A3A55"
        android:minWidth="0dp" android:minHeight="0dp"
        android:paddingHorizontal="8dp" android:paddingVertical="2dp"
        android:layout_marginEnd="4dp"
        android:visibility="gone"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/trackName"
        android:textColor="#E0E0F0" android:textSize="11sp"
        android:ellipsize="end" android:maxLines="1"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/typeLabel"
        android:textColor="#666677" android:textSize="10sp"
        android:layout_marginStart="4dp"
        android:visibility="gone"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <!-- Spacer pushes file indicator and play button to the right -->
    <View android:layout_weight="1"
        android:layout_width="0dp" android:layout_height="0dp"/>

    <TextView android:id="@+id/fileIndicator"
        android:textColor="#555568" android:textSize="10sp"
        android:ellipsize="end" android:maxLines="1"
        android:layout_marginStart="4dp"
        android:maxWidth="100dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <Button android:id="@+id/playBtn"
        android:textColor="#E0E0F0" android:textSize="10sp"
        android:backgroundTint="#3A3A55"
        android:minWidth="0dp" android:minHeight="0dp"
        android:paddingHorizontal="8dp" android:paddingVertical="2dp"
        android:layout_marginStart="4dp"
        android:visibility="gone"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

</LinearLayout>
